@using Blog.Common.DTOs.Post
@model IEnumerable<PostDTO>

<!-- Hero Section -->

<div id="heroCarousel" class="carousel slide carousel-fade mb-5" data-bs-ride="carousel">
    <div class="carousel-inner">

       
        <div class="carousel-item active">
            <div class="carousel-slide bg-primary-gradient">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold">Welcome to Our Blog</h1>
                    <p class="lead fs-4">
                        Discover insightful articles, tutorials, and inspiring stories.
                    </p>
                    <a href="#blog-posts" class="btn btn-light btn-lg">
                        Explore Articles
                    </a>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-slide bg-danger-gradient">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold">Learn Something New Every Day</h1>
                    <p class="lead fs-4">
                        Stay updated with technology, lifestyle, and innovation.
                    </p>
                    <a href="#blog-posts" class="btn btn-light btn-lg">
                        Read Latest Posts
                    </a>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-slide bg-info-gradient">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold">Share Ideas & Inspiration</h1>
                    <p class="lead fs-4">
                        Explore knowledge and experiences from talented writers.
                    </p>
                    <a href="#blog-posts" class="btn btn-light btn-lg">
                        Start Reading
                    </a>
                </div>
            </div>
        </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
   

</div>

<div class="container" id="blog-posts">

 
    <div class="text-center mb-5">
        <h2 class="display-4 fw-bold text-primary">
            <i class="bi bi-journal-richtext"></i>
            Blog Collection
        </h2>

        <p class="lead text-muted">
            Explore our latest articles, tutorials, and featured stories.
        </p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center p-5">
            <i class="bi bi-info-circle-fill fs-1 d-block mb-3"></i>
            <h4>No Posts Available</h4>
            <p>There are currently no blog posts available.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

            @foreach (var post in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm blog-card">

                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <img src="@post.ImageUrl"
                                 class="card-img-top blog-image">
                        }
                        else
                        {
                            <div class="card-img-top bg-gradient-primary d-flex justify-content-center align-items-center"
                                 style="height:250px">
                                <i class="bi bi-journal-richtext text-white display-1"></i>
                            </div>
                        }

                    <div class="card-body">

                        <span class="badge bg-primary mb-2">
                            @post.CategoryName
                        </span>

                        <h5 class="card-title fw-bold">
                            @post.Title
                        </h5>

                        <p class="card-text text-muted">
                            @(string.IsNullOrWhiteSpace(post.Description)
                                                    ? "No description available."
                                                    : post.Description.Length > 120
                                                    ? post.Description.Substring(0, 120) + "..."
                                                    : post.Description)
                    </p>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <a asp-controller="Post"
                               asp-action="Details"
                               asp-route-id="@post.Id"
                               class="btn btn-primary w-100">

                                <i class="bi bi-book"></i>
                                Read More

                            </a>

                        </div>

                    </div>
                </div>
                }

        </div>

        <div class="row mt-5">
            <div class="col-12">

                <div class="card shadow-lg border-0 stats-card">

                    <div class="card-body">

                        <h3 class="text-center mb-4">
                            Blog Statistics
                        </h3>

                        <div class="row text-center">

                            <div class="col-md-4">
                                <i class="bi bi-file-earmark-text-fill text-primary display-4"></i>
                                <h2>@Model.Count()</h2>
                                <p>Total Posts</p>
                            </div>

                            <div class="col-md-4">
                                <i class="bi bi-tags-fill text-success display-4"></i>
                                <h2>@Model.Select(x => x.CategoryName).Distinct().Count()</h2>
                                <p>Categories</p>
                            </div>

                            <div class="col-md-4">
                                <i class="bi bi-journal-check text-danger display-4"></i>
                                <h2>@Model.Count()</h2>
                                <p>Published Articles</p>
                            </div>

                        </div>

                    </div>

                </div>

            </div>
        </div>
    }
    

</div>

<style>

    body {
        background: #f8fafc;
    }

    .carousel-slide {
        height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
    }

    .bg-primary-gradient {
        background: linear-gradient(135deg,#667eea,#764ba2);
    }

    .bg-danger-gradient {
        background: linear-gradient(135deg,#f093fb,#f5576c);
    }

    .bg-info-gradient {
        background: linear-gradient(135deg,#4facfe,#00f2fe);
    }

    .carousel-caption-custom {
        animation: fadeInUp .8s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .blog-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        transition: .3s;
    }

        .blog-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }

    .blog-image {
        height: 250px;
        object-fit: cover;
        transition: .4s;
    }

    .blog-card:hover .blog-image {
        transform: scale(1.05);
    }

    .card-title {
        min-height: 60px;
    }

    .card-text {
        min-height: 80px;
    }

    .stats-card {
        border-radius: 20px;
        background: linear-gradient(135deg,#ffffff,#f1f5f9);
    }

    @@media(max-width:768px) {

        .carousel-slide {
            height: 350px;
        }

        .carousel-caption-custom h1 {
            font-size: 2rem;
        }
    }
</style>


<!-- Custom Styles -->
<style>
    /* Carousel Styles */
    .carousel-slide {
        height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .carousel-caption-custom {
        text-align: center;
        color: white;
        z-index: 10;
        animation: fadeInUp 1s ease-in-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .carousel-fade .carousel-item {
        transition: opacity 1s ease-in-out;
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        background-color: rgba(0, 0, 0, 0.5);
        border-radius: 50%;
        padding: 20px;
    }

    /* Divider Styles */
    .divider-custom {
        display: flex;
        align-items: center;
        margin: 2rem 0;
    }

    .divider-line {
        flex: 1;
        height: 2px;
        background: linear-gradient(90deg, transparent, #667eea, transparent);
    }

    .divider-icon {
        padding: 0 1rem;
        font-size: 1.5rem;
        color: #667eea;
    }

    /* Card Hover Effects */
    .hover-shadow {
        transition: all 0.3s ease-in-out;
        border-radius: 15px;
    }

    .hover-shadow:hover {
        transform: translateY(-10px);
        box-shadow: 0 1.5rem 4rem rgba(0,0,0,.2) !important;
    }

    .villa-image {
        transition: transform 0.5s ease-in-out;
    }

    .card:hover .villa-image {
        transform: scale(1.1);
    }

    .card {
        border: none;
        overflow: hidden;
        border-radius: 15px;
    }

    .transition {
        transition: all 0.3s ease;
    }

    /* Button Hover Effect */
    .btn-hover {
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .btn-hover:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    /* Stats Card */
    .stats-card {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-radius: 15px;
    }

    .stat-item {
        padding: 1rem;
        transition: transform 0.3s ease;
    }

    .stat-item:hover {
        transform: translateY(-5px);
    }

    /* Background Gradient */
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    /* Smooth Scroll */
    .smooth-scroll {
        scroll-behavior: smooth;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .carousel-slide {
            height: 400px;
        }

        .carousel-caption-custom h1 {
            font-size: 2rem;
        }

        .carousel-caption-custom p {
            font-size: 1rem;
        }
    }
</style>
