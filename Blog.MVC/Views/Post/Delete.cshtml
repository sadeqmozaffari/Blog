@model Blog.Common.DTOs.Post.PostDTO

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Form Card -->
            <div class="card">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold h4 pt-1">Delete Post</span>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Id" />
                        <!-- Post Name -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">
                                Post Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" disabled class="form-control" placeholder="Enter Post name" />
                        </div>
                        <!-- Details -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" disabled class="form-control" rows="4"
                                      placeholder="Describe the Post"></textarea>
                        </div>
                        <!-- Rate and Occupancy -->
                        
                            <div class="mb-3">
                                <label asp-for="CategoryId" class="form-label">
                                    Nightly Rate <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">Category</span>
                                    <input asp-for="CategoryId" class="form-control" placeholder="" />
                                </div>
                            </div>
                          
                        <

                     

                        <!-- Image URL -->
                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label">Image URL</label>
                            <input asp-for="ImageUrl" disabled class="form-control" placeholder="https://example.com/image.jpg" />
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="text-center mb-4">
                                <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded" style="max-height: 350px;">
                            </div>
                        }

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-check me-2"></i>Delete Post
                            </button>
                        </div>


                       
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
