@model Blog.Common.DTOs.Post.PostCreateDTO

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Form Card -->
            <div class="card">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold h4 pt-1">Create Post</span>
                </div>
                <div class="card-body">
                    <form method="post">

                        <!-- Post Name -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">
                                Post Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="Enter Post name" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Describe the Post"></textarea>
                            <span  asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                  

                        <!-- Sqft -->
                        <div class="mb-3">
                            <label asp-for="CategoryId"  class="form-label">Category</label>
                            <input asp-for="CategoryId" type="number" class="form-control" placeholder="" />
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <!-- Image URL -->
                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label">Image URL</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check me-2"></i>Create Post
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
