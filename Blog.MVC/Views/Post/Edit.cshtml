@model Blog.Common.DTOs.Post.PostCreateDTO

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Form Card -->
            <div class="card">
                <div class="card-header bg-warning text-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold h4 pt-1">Update Post</span>
                </div>
                <div class="card-body">
                    <form method="post">

                        <!-- Post Title -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">
                                Post Title <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="Enter Post Title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Describe the Post"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                      
                        <!-- Sqft -->
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Category</label>
                            <input asp-for="CategoryId"  class="form-control" placeholder="" />
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <!-- Image URL -->
                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label">Image URL</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="text-center mb-4">
                                <label> Current Image</label> <br/>
                                <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded" style="max-height: 350px;">
                            </div>
                        }

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check me-2"></i>Update Post
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial Title="_ValidationScriptsPartial" />
}
